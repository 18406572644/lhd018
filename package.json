{
  "name": "quick-account",
  "version": "1.0.0",
  "description": "自定义分类快捷记账桌面小工具",
  "main": "electron/main.js",
  "scripts": {
    "serve": "vue-cli-service serve",
    "build": "vue-cli-service build",
    "electron:dev": "concurrently \"npm run serve\" \"wait-on http://localhost:8080 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && electron-builder",
    "start": "electron ."
  },
  "dependencies": {
    "core-js": "^3.8.3",
    "echarts": "^5.4.3",
    "element-ui": "^2.15.14",
    "jspdf": "^4.2.1",
    "tesseract.js": "^7.0.0",
    "vue": "^2.7.14",
    "vue-router": "^3.6.5"
  },
  "devDependencies": {
    "@vue/cli-plugin-babel": "~5.0.0",
    "@vue/cli-service": "~5.0.0",
    "babel-plugin-component": "^1.1.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "sass": "^1.69.5",
    "sass-loader": "^13.3.2",
    "vue-template-compiler": "^2.7.14",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.quickaccount.app",
    "productName": "快捷记账",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    }
  }
}
